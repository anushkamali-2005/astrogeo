# ============================================================================
# Docker Ignore File
# Exclude unnecessary files from Docker build context
# ============================================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv
virtualenv/
.conda/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
*.cover
.hypothesis/

# Documentation
docs/_build/
site/
.sphinx/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
wheels/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
logs/
*.log.*

# Database
*.db
*.sqlite
*.sqlite3

# Development files
Makefile
*.md
LICENSE
.gitignore
.gitattributes

# CI/CD
.github/
.gitlab-ci.yml
.circleci/

# Git
.git/
.gitignore

# Data files (use volumes instead)
data/
*.csv
*.json
*.parquet
*.pkl
*.pickle

# Model files (use volumes or S3)
models/
*.h5
*.pt
*.pth
*.onnx
*.pb

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
Thumbs.db
.DS_Store

# Docker files (don't need in container)
docker-compose*.yml
Dockerfile*
.dockerignore

# Scripts that run outside container
scripts/local_*
scripts/dev_*

# Test files (if not needed)
tests/
*.test.py

# Coverage reports
coverage.xml
.coverage

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Profiling
*.prof
*.lprof

# Pre-commit
.pre-commit-config.yaml

# Node (if any)
node_modules/
npm-debug.log

# Kubernetes
k8s/
*.yaml
*.yml

# Backup files
*.bak
*.backup
*~

# Large binary files
*.zip
*.tar.gz
*.rar
*.7z

